# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup

# Secrets — ignore encrypted/plaintext .yaml files to prevent accidental commits.
# The secrets/ directory itself is tracked so README and .template files are versioned.
# Encrypted .yaml files (safe to commit) must be added explicitly: git add -f secrets/...
secrets/**/*.yaml
*.age

# Nix
result

# Scratch / debug output directories
errors/

# Old configs (contain their own .git, not submodules)
pluto-config/
old-config/
