# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup

# Secrets
# We commit the *encrypted* .yaml files (standard sops-nix practice).
# Only ignore plaintext backups or temporary decrypted files.
secrets/**/*.decrypted
secrets/**/*.bak
secrets/**/.sops.yaml   # optional editor backup

# Still ignore age private keys (never commit these)
*.age

# Nix
result

# Scratch / debug output directories
errors/

# Old configs (contain their own .git, not submodules)
pluto-config/
old-config/
