{
  "$schema": "./schema.json",
  "machines": {
    "testbed": {
      "hostname": "testbed",
      "description": "Testing and development laptop",
      "address": "192.168.50.200",
      "tags": [
        "testing"
      ],
      "users": {
        "admin": [
          "voyager"
        ],
        "regular": []
      },
      "os": {
        "type": "nixos",
        "system": "x86_64-linux",
        "role": "testing",
        "modules": [
          "desktop",
          "web-utils",
          "maintenance"
        ]
      },
      "hardware": {
        "form": "laptop",
        "disk": {
          "device": "/dev/sda",
          "swap": "8G",
          "format": "xfs"
        }
      }
    },
    "pluto": {
      "hostname": "pluto",
      "description": "Primary workstation",
      "address": "192.168.50.201",
      "tags": [
        "workstation",
        "physical"
      ],
      "users": {
        "admin": [
          "voyager"
        ],
        "regular": []
      },
      "os": {
        "type": "nixos",
        "system": "x86_64-linux",
        "role": "pluto",
        "modules": [
          "desktop",
          "web-utils",
          "maintenance"
        ]
      },
      "hardware": {
        "form": "desktop",
        "disk": {
          "device": "/dev/nvme0n1",
          "swap": "32G",
          "format": "xfs"
        }
      }
    }
  }
}